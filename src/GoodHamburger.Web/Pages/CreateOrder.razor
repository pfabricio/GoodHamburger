@page "/create-order"
@using GoodHamburger.Web.Models
@using GoodHamburger.Web.Services
@inject MenuService MenuService
@inject OrderService OrderService
@inject NavigationManager Navigation

<PageTitle>🛒 Novo Pedido - Good Hamburger</PageTitle>

<div class="container mt-4">
    <h1 class="mb-4">🛒 Criar Pedido</h1>
    
    @if (isLoading)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @* Seleção de Produtos *@
            <div class="col-md-7">
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">📋 Selecione os Itens</h5>
                        <small>Adicione quantos itens quiser</small>
                    </div>
                    <div class="card-body">
                        @foreach (var typeGroup in menuItems.GroupBy(m => m.Type).OrderBy(g => g.Key))
                        {
                            <div class="mb-4">
                                <h6 class="text-muted text-uppercase">@typeGroup.First().TypeDisplay</h6>
                                <div class="row g-2">
                                    @foreach (var item in typeGroup)
                                    {
                                        <div class="col-6">
                                            <div class="card @(GetQuantity(item.Id) > 0 ? "border-success" : "border-light")">
                                                <div class="card-body p-3">
                                                    <span class="fs-4">@item.Icon</span>
                                                    <div class="fw-bold">@item.Name</div>
                                                    <div class="text-success">R$ @item.Price.ToString("F2")</div>
                                                    @if (GetQuantity(item.Id) > 0)
                                                    {
                                                        <div class="d-flex gap-1 mt-2">
                                                            <button class="btn btn-sm btn-outline-danger flex-1" @onclick="() => RemoveItem(item)">
                                                                -
                                                            </button>
                                                            <span class="btn btn-sm btn-success flex-1">@GetQuantity(item.Id)</span>
                                                            <button class="btn btn-sm btn-outline-success flex-1" @onclick="() => AddItem(item)">
                                                                +
                                                            </button>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-success w-100 mt-2"
                                                                @onclick="() => AddItem(item)">
                                                            + Adicionar
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            
            @* Carrinho e Resumo *@
            <div class="col-md-5">
                <div class="card sticky-top" style="top: 20px;">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">🛍️ Seu Pedido</h5>
                    </div>
                    <div class="card-body">
                        @* Nome do Cliente *@
                        <div class="mb-3">
                            <label class="form-label">Nome do Cliente</label>
                            <input type="text" class="form-control" @bind="customerName" placeholder="Seu nome (opcional)" />
                        </div>
                        
                        <hr />
                        
                        @* Itens Selecionados *@
                        @if (selectedItems.Count == 0)
                        {
                            <p class="text-muted text-center">Nenhum item selecionado</p>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush mb-3">
                                @foreach (var item in selectedItems)
                                {
                                    var qty = GetQuantity(item.Id);
                                    if (qty > 0)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <div>
                                                <span>@item.Icon</span>
                                                <span>@item.Name</span>
                                                <span class="badge bg-secondary ms-2">x@(qty)</span>
                                            </div>
                                            <span>R$ @((item.Price * qty).ToString("F2"))</span>
                                        </li>
                                    }
                                }
                            </ul>
                            
                            @* Cálculos *@
                            <div class="border-top pt-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Subtotal:</span>
                                    <span>R$ @CalculateSubtotal().ToString("F2")</span>
                                </div>
                                
                                @if (GetDiscountPercentage() > 0)
                                {
                                    <div class="d-flex justify-content-between mb-2 text-success">
                                        <span>
                                            Desconto @((GetDiscountPercentage() * 100).ToString("F0"))%:
                                            <br />
                                            <small>@GetDiscountDescription()</small>
                                        </span>
                                        <span>-R$ @CalculateDiscount().ToString("F2")</span>
                                    </div>
                                }
                                
                                <div class="d-flex justify-content-between fw-bold fs-5 border-top pt-2 mt-2">
                                    <span>Total:</span>
                                    <span class="text-success">R$ @CalculateTotal().ToString("F2")</span>
                                </div>
                            </div>
                            
                            @* Botão Limpar Carrinho *@
                            <button class="btn btn-outline-danger w-100 mt-2" 
                                    @onclick="ClearCart"
                                    disabled="@(selectedItems.Count == 0)">
                                🗑️ Limpar Carrinho
                            </button>
                        }
                        
                        @* Botão Finalizar *@
                        <button class="btn btn-primary w-100 mt-3" 
                                @onclick="SubmitOrder"
                                disabled="@(selectedItems.Count == 0 || isSubmitting)">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                <span class="ms-2">Criando...</span>
                            }
                            else
                            {
                                <span>✅ Finalizar Pedido</span>
                            }
                        </button>
                        
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger mt-3 mb-0">
                                @errorMessage
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<MenuItemDto> menuItems = new();
    private List<MenuItemDto> selectedItems = new();
    private Dictionary<int, int> itemQuantities = new();
    private string? customerName;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            menuItems = await MenuService.GetMenuAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar cardápio: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private int GetQuantity(int id) => itemQuantities.GetValueOrDefault(id, 0);

    private void AddItem(MenuItemDto item)
    {
        if (!itemQuantities.ContainsKey(item.Id))
        {
            itemQuantities[item.Id] = 0;
            selectedItems.Add(item);
        }
        itemQuantities[item.Id]++;
        errorMessage = null;
        StateHasChanged();
    }

    private void RemoveItem(MenuItemDto item)
    {
        if (itemQuantities.ContainsKey(item.Id))
        {
            itemQuantities[item.Id]--;
            if (itemQuantities[item.Id] <= 0)
            {
                itemQuantities.Remove(item.Id);
                selectedItems.RemoveAll(i => i.Id == item.Id);
            }
        }
        errorMessage = null;
        StateHasChanged();
    }

    private void ClearCart()
    {
        itemQuantities.Clear();
        selectedItems.Clear();
        errorMessage = null;
        StateHasChanged();
    }

    private decimal CalculateSubtotal() => selectedItems.Sum(i => i.Price * GetQuantity(i.Id));

    private decimal GetDiscountPercentage()
    {
        var hasSandwich = selectedItems.Any(i => i.Type == ItemType.Sandwich && GetQuantity(i.Id) > 0);
        var hasSide = selectedItems.Any(i => i.Type == ItemType.Side && GetQuantity(i.Id) > 0);
        var hasDrink = selectedItems.Any(i => i.Type == ItemType.Drink && GetQuantity(i.Id) > 0);

        if (hasSandwich && hasSide && hasDrink) return 0.20m;
        if (hasSandwich && hasDrink) return 0.15m;
        if (hasSandwich && hasSide) return 0.10m;
        return 0m;
    }

    private string GetDiscountDescription()
    {
        var hasSandwich = selectedItems.Any(i => i.Type == ItemType.Sandwich && GetQuantity(i.Id) > 0);
        var hasSide = selectedItems.Any(i => i.Type == ItemType.Side && GetQuantity(i.Id) > 0);
        var hasDrink = selectedItems.Any(i => i.Type == ItemType.Drink && GetQuantity(i.Id) > 0);

        if (hasSandwich && hasSide && hasDrink) return "Combo Completo (Sanduíche + Acompanhamento + Bebida)";
        if (hasSandwich && hasDrink) return "Sanduíche + Bebida";
        if (hasSandwich && hasSide) return "Sanduíche + Acompanhamento";
        return "";
    }

    private decimal CalculateDiscount() => CalculateSubtotal() * GetDiscountPercentage();

    private decimal CalculateTotal() => CalculateSubtotal() - CalculateDiscount();

    private async Task SubmitOrder()
    {
        if (itemQuantities.Count == 0) return;

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var request = new CreateOrderRequest
            {
                CustomerName = customerName,
                Items = itemQuantities.Select(kvp => new CreateOrderItemRequest
                {
                    MenuItemId = kvp.Key,
                    Quantity = kvp.Value
                }).ToList()
            };

            var order = await OrderService.CreateOrderAsync(request);
            Navigation.NavigateTo($"/order-confirmation/{order.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao criar pedido: {ex.Message}";
            isSubmitting = false;
        }
    }
}
