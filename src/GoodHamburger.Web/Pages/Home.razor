@page "/"

<PageTitle>🍔 Good Hamburger</PageTitle>

<div class="container mt-5">
    <div class="text-center">
        <div class="display-1 mb-3">🍔</div>
        <h1 class="display-4 fw-bold">Good Hamburger</h1>
        <p class="lead text-muted">O melhor hambúrguer da cidade!</p>
    </div>

    <div class="row mt-5">
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100">
                <div class="card-body d-flex flex-column">
                    <div class="fs-1 mb-3">📋</div>
                    <h5 class="card-title">Ver Cardápio</h5>
                    <p class="card-text">Confira nossos deliciosos sanduíches, acompanhamentos e bebidas.</p>
                    <a href="menu" class="btn btn-primary mt-auto">Ver Cardápio</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100">
                <div class="card-body d-flex flex-column">
                    <div class="fs-1 mb-3">🛒</div>
                    <h5 class="card-title">Fazer Pedido</h5>
                    <p class="card-text">Monte seu pedido e aproveite nossos combos com desconto!</p>
                    <a href="create-order" class="btn btn-success mt-auto">Novo Pedido</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-center h-100">
                <div class="card-body d-flex flex-column">
                    <div class="fs-1 mb-3">📦</div>
                    <h5 class="card-title">Meus Pedidos</h5>
                    <p class="card-text">Acompanhe todos os seus pedidos e seu histórico.</p>
                    <a href="orders" class="btn btn-info mt-auto">Ver Pedidos</a>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-info mt-4 text-center">
        <h5>💰 Promoções Especiais</h5>
        <div class="row mt-3">
            <div class="col-md-4">
                <strong>🍔 + 🍟 + 🥤</strong><br />
                <span class="badge bg-success">20% OFF</span>
            </div>
            <div class="col-md-4">
                <strong>🍔 + 🥤</strong><br />
                <span class="badge bg-success">15% OFF</span>
            </div>
            <div class="col-md-4">
                <strong>🍔 + 🍟</strong><br />
                <span class="badge bg-success">10% OFF</span>
            </div>
        </div>
    </div>
</div>
