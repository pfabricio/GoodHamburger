@page "/order-confirmation/{OrderId:int}"
@using GoodHamburger.Web.Models
@using GoodHamburger.Web.Services
@inject OrderService OrderService
@inject NavigationManager Navigation

<PageTitle>✅ Pedido Confirmado - Good Hamburger</PageTitle>

<div class="container mt-4">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
        </div>
    }
    else if (order == null)
    {
        <div class="alert alert-danger">
            <h4>Pedido não encontrado</h4>
            <p>O pedido solicitado não existe ou foi removido.</p>
            <button class="btn btn-primary" @onclick="GoHome">Voltar ao Início</button>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-8">
                @* Header de Sucesso *@
                <div class="text-center mb-4">
                    <div class="display-1 text-success mb-3">🎉</div>
                    <h1 class="text-success">Pedido Confirmado!</h1>
                    <p class="lead">Seu pedido foi registrado com sucesso.</p>
                </div>
                
                @* Card do Pedido *@
                <div class="card border-success">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">🧾 Pedido #@order.Id</h5>
                        <span class="badge bg-light text-dark">@order.StatusDisplay</span>
                    </div>
                    <div class="card-body">
                        @* Informações do Cliente *@
                        @if (!string.IsNullOrEmpty(order.CustomerName))
                        {
                            <div class="mb-3">
                                <strong>Cliente:</strong> @order.CustomerName
                            </div>
                        }
                        
                        @* Data *@
                        <div class="mb-3 text-muted">
                            <small>📅 @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        
                        <hr />
                        
                        @* Itens *@
                        <h6 class="mb-3">Itens do Pedido:</h6>
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var item in order.Items)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <span>@(GetIconForType(item.Type))</span>
                                        <span class="ms-2">@item.Name</span>
                                    </div>
                                    <span>R$ @item.UnitPrice.ToString("F2")</span>
                                </li>
                            }
                        </ul>
                        
                        @* Resumo Financeiro *@
                        <div class="border-top pt-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Subtotal:</span>
                                <span>R$ @order.Subtotal.ToString("F2")</span>
                            </div>
                            
                            @if (order.DiscountPercentage > 0)
                            {
                                <div class="d-flex justify-content-between mb-2 text-success">
                                    <span>
                                        Desconto @((order.DiscountPercentage * 100).ToString("F0"))%
                                        <i class="bi bi-check-circle"></i>
                                    </span>
                                    <span>-R$ @order.DiscountAmount.ToString("F2")</span>
                                </div>
                                <div class="text-success small mb-2">
                                    💰 Você economizou R$ @order.DiscountAmount.ToString("F2")!
                                </div>
                            }
                            
                            <div class="d-flex justify-content-between fw-bold fs-4 border-top pt-2 mt-2">
                                <span>Total:</span>
                                <span class="text-success">R$ @order.Total.ToString("F2")</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                @* Botões de Ação *@
                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button class="btn btn-primary" @onclick="CreateNewOrder">
                        🛒 Fazer Novo Pedido
                    </button>
                    <button class="btn btn-outline-primary" @onclick="ViewOrders">
                        📋 Ver Todos os Pedidos
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="GoHome">
                        🏠 Início
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int OrderId { get; set; }

    private OrderResponseDto? order;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            order = await OrderService.GetOrderByIdAsync(OrderId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading order: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetIconForType(ItemType type) => type switch
    {
        ItemType.Sandwich => "🍔",
        ItemType.Side => "🍟",
        ItemType.Drink => "🥤",
        _ => "📦"
    };

    private void CreateNewOrder() => Navigation.NavigateTo("/create-order");
    private void ViewOrders() => Navigation.NavigateTo("/orders");
    private void GoHome() => Navigation.NavigateTo("/");
}
